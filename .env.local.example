# Copy to .env.local and fill in
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# APP RUNTIME (this is what Vercel prod carries).
# Scoped `coach_app` Postgres role via the Supavisor pooler: EXECUTE on the 3 coach
# functions, zero table grants. It cannot read the CRM. Do NOT put a service_role key here.
#   postgresql://coach_app.<project_ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
COACH_DATABASE_URL=

# Optional. Global daily spend ceiling in cents. Defaults to 300 (USD 3.00/day).
COACH_DAILY_BUDGET_CENTS=

# ADMIN ONLY - used by scripts/embed-corpus.ts, run from a laptop. NOT set in Vercel.
# The deployed app never reads these.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
